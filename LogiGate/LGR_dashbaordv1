
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LogiGate — LGR Request Register</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0E1C26; --ink-2:#16293A; --ink-3:#1E3448;
  --paper:#F2F4F3; --card:#FFFFFF; --line:#E0E5E4; --line-2:#C8D1CF;
  --txt:#152430; --slate:#46565F; --mute:#7E8B94;
  --teal:#0D8A72; --teal-d:#0A6B59; --teal-bg:#E0F2ED;
  --blue:#2D6FB2; --blue-bg:#E4EEF8;
  --violet:#6A5ACD; --violet-bg:#ECE9FA;
  --amber:#B4720C; --amber-bg:#FBF0DA;
  --red:#B23434; --red-bg:#FAE7E7;
  --green:#2E7D32; --green-bg:#E5F2E6;
  --gray-bg:#EBEEED;
  --mono:'IBM Plex Mono',ui-monospace,monospace; --disp:'Sora',sans-serif;
  --sh:0 1px 2px rgba(14,28,38,.05),0 4px 14px rgba(14,28,38,.06);
  --sh-lg:0 8px 32px rgba(14,28,38,.16);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'IBM Plex Sans',system-ui,sans-serif;background:var(--paper);color:var(--txt);font-size:14px;line-height:1.5}
button{font:inherit;cursor:pointer}
::-webkit-scrollbar{width:10px;height:10px}::-webkit-scrollbar-thumb{background:var(--line-2);border-radius:5px}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation:none!important;transition:none!important}}

/* ---------- layout: sidebar + content ---------- */
.app{min-height:100vh}
.side{width:236px;background:var(--ink);color:#D7E1E6;flex-shrink:0;display:flex;flex-direction:column;position:sticky;top:0;height:100vh}
.side .brand{padding:22px 20px 18px;border-bottom:1px solid var(--ink-3)}
.side .brand .nm{font-family:var(--disp);font-weight:700;font-size:16px;color:#fff;letter-spacing:.01em;display:flex;align-items:center;gap:9px}
.brand .mark{width:26px;height:26px;border-radius:7px;background:linear-gradient(135deg,#0D8A72,#2D6FB2);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;font-family:var(--disp)}
.side .brand .ap{font-size:11px;color:#6E8492;font-family:var(--mono);margin-top:6px}
.nav{padding:14px 12px;flex:1;overflow-y:auto}
.nav .sect{font-size:10.5px;text-transform:uppercase;letter-spacing:.1em;color:#5F7683;padding:12px 10px 6px;font-weight:600}
.nav a{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:8px;color:#B9C8D0;text-decoration:none;font-size:13.5px;font-weight:500;cursor:pointer;transition:background .12s,color .12s}
.nav a:hover{background:var(--ink-2);color:#fff}
.nav a.on{background:var(--ink-3);color:#fff}
.nav a .ic{width:18px;text-align:center;font-size:14px;opacity:.9}
.nav a .bd{margin-left:auto;background:var(--ink-3);border:1px solid #2A455C;color:#CBD9E0;font-family:var(--mono);font-size:11px;padding:1px 8px;border-radius:10px}
.nav a.on .bd{background:#0D8A72;border-color:#0D8A72;color:#fff}
.side .foot{padding:14px 20px;border-top:1px solid var(--ink-3);font-size:11px;color:#6E8492;font-family:var(--mono);line-height:1.7}
.main{width:100%}
.head{background:var(--card);border-bottom:1px solid var(--line);padding:18px 32px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:30}
.head h1{font-family:var(--disp);font-size:19px;font-weight:600;letter-spacing:-.01em}
.head .sub{font-size:12.5px;color:var(--mute)}
.head .spacer{flex:1}
.htabs{display:flex;gap:2px;background:var(--paper);border:1px solid var(--line);border-radius:10px;padding:3px}
.htabs button{background:transparent;border:0;color:var(--slate);padding:7px 16px;border-radius:8px;font-size:13.5px;font-weight:500}
.htabs button.on{background:var(--ink);color:#fff}
.hbd{font-family:var(--mono);font-size:11px;background:rgba(255,255,255,.18);padding:1px 7px;border-radius:9px;margin-left:4px}
.htabs button:not(.on) .hbd{background:var(--gray-bg);color:var(--slate)}
@media(max-width:760px){.head{flex-wrap:wrap}.htabs{order:3;width:100%;justify-content:center}}
.pill-live{display:flex;align-items:center;gap:7px;font-size:12px;color:var(--slate);background:var(--paper);border:1px solid var(--line);padding:6px 14px;border-radius:20px;font-family:var(--mono)}
.pill-live .pulse{width:8px;height:8px;border-radius:50%;background:var(--teal);animation:pl 2.2s infinite}
@keyframes pl{0%,100%{box-shadow:0 0 0 0 rgba(13,138,114,.4)}55%{box-shadow:0 0 0 6px rgba(13,138,114,0)}}
.content{padding:26px 32px 70px;max-width:1240px;margin:0 auto}
@media(max-width:880px){.content,.head{padding-left:16px;padding-right:16px}}

/* ---------- KPI cards ---------- */
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(168px,1fr));gap:14px;margin-bottom:22px}
.kpi{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 18px 14px;cursor:pointer;box-shadow:var(--sh);transition:transform .14s,box-shadow .14s;position:relative;overflow:hidden}
.kpi:hover{transform:translateY(-2px);box-shadow:var(--sh-lg)}
.kpi::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--kc,transparent)}
.kpi .lbl{font-size:11px;color:var(--mute);text-transform:uppercase;letter-spacing:.08em;font-weight:600}
.kpi .val{font-family:var(--disp);font-size:32px;font-weight:700;margin-top:4px;letter-spacing:-.02em;color:var(--kc,var(--txt))}
.kpi .hint{font-size:12px;color:var(--mute);margin-top:1px}

/* ---------- pipeline flow board (signature) ---------- */
.flowboard{background:var(--ink);border-radius:16px;padding:22px 26px 20px;margin-bottom:22px;color:#D7E1E6;box-shadow:var(--sh)}
.flowboard h3{font-family:var(--disp);font-size:13px;font-weight:600;color:#9FB4BF;letter-spacing:.04em;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.flowboard h3 .cl{margin-left:auto;font-family:var(--mono);font-size:11.5px;color:#6E8492;text-transform:none;letter-spacing:0;font-weight:400}
.flow{display:flex;align-items:stretch;gap:0}
.fstage{flex:1;position:relative;cursor:pointer;padding:0 4px}
.fstage .fbar{height:64px;border-radius:10px;background:var(--ink-2);position:relative;overflow:hidden;display:flex;align-items:flex-end;transition:outline-color .12s;outline:2px solid transparent}
.fstage:hover .fbar{outline-color:#3E617E}
.fstage .ff{width:100%;background:linear-gradient(180deg,#12A98C,#0D8A72);border-radius:10px 10px 0 0;transition:height .9s cubic-bezier(.2,.7,.2,1);height:0}
.fstage.warn .ff{background:linear-gradient(180deg,#D99425,#B4720C)}
.fstage.calm .ff{background:linear-gradient(180deg,#3E7FC4,#2D6FB2)}
.fstage .fnum{position:absolute;top:8px;left:0;right:0;text-align:center;font-family:var(--disp);font-weight:700;font-size:19px;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,.3)}
.fstage .flbl{text-align:center;font-size:11px;color:#9FB4BF;margin-top:8px;line-height:1.35}
.fstage .fpct{text-align:center;font-family:var(--mono);font-size:10.5px;color:#6E8492}
.farrow{align-self:center;color:#3E617E;font-size:15px;padding:0 2px;margin-bottom:34px}

/* ---------- panels & bars ---------- */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
@media(max-width:940px){.grid2{grid-template-columns:1fr}}
.panel{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px 20px;box-shadow:var(--sh)}
.panel h3{font-family:var(--disp);font-size:13.5px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.panel h3 .tag{font-family:var(--mono);font-weight:400;font-size:11px;color:var(--mute);margin-left:auto}
.brow{display:flex;align-items:center;gap:10px;margin-bottom:8px;font-size:12.5px}
.brow .bl{width:186px;color:var(--slate);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0;cursor:pointer;display:flex;align-items:center;gap:7px}
.brow .bl:hover{color:var(--txt)}
.brow .bl .dsk{width:20px;height:20px;border-radius:6px;font-size:9.5px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--disp)}
.brow .bt{flex:1;background:var(--gray-bg);border-radius:4px;height:18px;overflow:hidden}
.brow .bf{height:100%;border-radius:4px;width:0;transition:width .8s cubic-bezier(.2,.7,.2,1)}
.brow .bv{font-family:var(--mono);font-size:12px;width:26px;text-align:right;color:var(--slate)}
.hist{display:flex;align-items:flex-end;gap:14px;height:150px;padding:6px 4px 0}
.hcol{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end;cursor:pointer}
.hcol .hb{width:100%;max-width:64px;border-radius:8px 8px 3px 3px;height:0;transition:height .8s cubic-bezier(.2,.7,.2,1);position:relative}
.hcol .hv{font-family:var(--mono);font-size:12px;color:var(--slate)}
.hcol .hl{font-size:11px;color:var(--mute);white-space:nowrap}
.qrow{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;cursor:pointer;transition:background .1s}
.qrow:hover{background:var(--paper)}
.qrow .qn{font-family:var(--mono);font-size:12.5px;font-weight:500;width:80px;flex-shrink:0}
.qrow .qs{flex:1;font-size:12.5px;color:var(--slate);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qrow .qo{font-size:11px;color:var(--mute);white-space:nowrap;max-width:150px;overflow:hidden;text-overflow:ellipsis}

/* ---------- chips & avatars ---------- */
.chip{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:500;white-space:nowrap}
.chip::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.75}
.f-appr{background:var(--blue-bg);color:var(--blue)} .f-pay{background:var(--violet-bg);color:var(--violet)}
.f-vend{background:var(--amber-bg);color:var(--amber)} .f-ver{background:var(--teal-bg);color:var(--teal-d)}
.f-done{background:var(--green-bg);color:var(--green)} .f-bad{background:var(--red-bg);color:var(--red)}
.f-gray{background:var(--gray-bg);color:var(--slate)}
.age-b{font-family:var(--mono);font-size:11.5px;padding:2px 9px;border-radius:5px;font-weight:500}
.a-ok{background:var(--gray-bg);color:var(--slate)} .a-warn{background:var(--amber-bg);color:var(--amber)} .a-bad{background:var(--red-bg);color:var(--red)}
.avt{width:26px;height:26px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;font-family:var(--disp);flex-shrink:0}

/* ---------- register ---------- */
.deskstrip{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
.deskstrip a{display:inline-flex;align-items:center;gap:7px;border:1px solid var(--line);background:var(--card);border-radius:20px;padding:7px 14px;font-size:12.5px;color:var(--slate);cursor:pointer;font-weight:500;box-shadow:var(--sh)}
.deskstrip a:hover{border-color:var(--line-2)}
.deskstrip a .bd{font-family:var(--mono);font-size:11px;background:var(--gray-bg);padding:1px 8px;border-radius:10px}
.deskstrip a .ic{font-size:9px}
.fbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:16px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:12px 14px;box-shadow:var(--sh)}
.fbar input[type=text]{flex:1;min-width:210px;padding:9px 13px;border:1px solid var(--line);border-radius:9px;font:inherit;font-size:13.5px;background:var(--paper)}
.fbar input:focus,.fbar select:focus{outline:2px solid var(--teal);outline-offset:-1px}
.fbar select{padding:9px 10px;border:1px solid var(--line);border-radius:9px;font:inherit;font-size:13px;background:var(--paper);color:var(--slate);max-width:210px}
.chip-t{border:1px solid var(--line);background:var(--paper);border-radius:9px;padding:8px 15px;font-size:13px;color:var(--slate);font-weight:500}
.chip-t.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.count-lbl{font-size:12px;color:var(--mute);margin-left:auto;font-family:var(--mono)}
.tbl-wrap{background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--sh)}
table{width:100%;border-collapse:collapse}
thead th{text-align:left;font-size:10.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--mute);font-weight:600;padding:11px 16px;border-bottom:1px solid var(--line);background:#FAFBFB;cursor:pointer;user-select:none;white-space:nowrap}
thead th:hover{color:var(--txt)}
thead th .sd{font-size:9px;margin-left:3px}
tbody td{padding:11px 16px;border-bottom:1px solid var(--line);font-size:13px;vertical-align:middle}
tbody tr{cursor:pointer;transition:background .1s}
tbody tr:hover{background:#F4F8F7}
tbody tr:last-child td{border-bottom:0}
.req-no{font-family:var(--mono);font-weight:500;font-size:12.5px;white-space:nowrap}
.rq-cell{display:flex;align-items:center;gap:9px}
.owner-cell{font-size:12.5px;color:var(--slate)}
.pager{display:flex;align-items:center;justify-content:center;gap:10px;padding:13px}
.pager button{border:1px solid var(--line);background:var(--card);border-radius:8px;padding:6px 14px;font-size:12.5px;color:var(--slate)}
.pager button:disabled{opacity:.4;cursor:default}
.pager span{font-size:12.5px;color:var(--mute);font-family:var(--mono)}
.empty{padding:46px;text-align:center;color:var(--mute);font-size:13.5px}

/* ---------- drawer ---------- */
.ovl{position:fixed;inset:0;background:rgba(10,20,28,.5);z-index:50;opacity:0;pointer-events:none;transition:opacity .2s;backdrop-filter:blur(2px)}
.ovl.on{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;right:-760px;width:min(730px,97vw);height:100vh;background:var(--card);z-index:60;transition:right .26s cubic-bezier(.2,.8,.3,1);display:flex;flex-direction:column;box-shadow:var(--sh-lg)}
.drawer.on{right:0}
.d-head{padding:20px 26px 16px;border-bottom:1px solid var(--line);display:flex;align-items:flex-start;gap:14px;background:linear-gradient(180deg,#FAFBFB,#fff)}
.d-head .rn{font-family:var(--disp);font-size:22px;font-weight:700;letter-spacing:-.01em;display:flex;align-items:center;gap:10px}
.d-head .cp{border:1px solid var(--line);background:var(--paper);border-radius:7px;font-size:11px;padding:3px 10px;color:var(--slate);font-family:var(--mono)}
.d-head .close{margin-left:auto;border:1px solid var(--line);background:var(--card);border-radius:9px;width:34px;height:34px;font-size:15px;color:var(--slate);transition:background .1s}
.d-head .close:hover{background:var(--paper)}
.d-body{overflow-y:auto;padding:22px 26px 46px;flex:1}
.d-sec{margin-bottom:24px}
.d-sec h4{font-size:11px;text-transform:uppercase;letter-spacing:.09em;color:var(--mute);font-weight:600;margin-bottom:11px;font-family:var(--disp)}
.meta-g{display:grid;grid-template-columns:1fr 1fr;gap:2px;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:var(--line)}
@media(max-width:560px){.meta-g{grid-template-columns:1fr}}
.meta-g .m{background:var(--card);padding:11px 15px}
.meta-g .m .k{font-size:11px;color:var(--mute)}
.meta-g .m .v{font-size:13.5px;margin-top:1px;word-break:break-word}
.pipe{display:flex;margin:6px 0 2px}
.pipe .st{flex:1;text-align:center;position:relative;padding-top:18px}
.pipe .st .nd{width:14px;height:14px;border-radius:50%;background:var(--gray-bg);border:2.5px solid var(--line-2);margin:0 auto 7px;position:relative;z-index:2;transition:transform .2s}
.pipe .st.done .nd{background:var(--teal);border-color:var(--teal)}
.pipe .st.cur .nd{background:#fff;border-color:var(--ink);box-shadow:0 0 0 4px rgba(14,28,38,.12);transform:scale(1.15)}
.pipe .st .sl{font-size:10.5px;color:var(--mute);line-height:1.3}
.pipe .st.cur .sl{color:var(--txt);font-weight:600}
.pipe .st.done .sl{color:var(--teal-d)}
.pipe .st::before{content:'';position:absolute;top:24px;left:-50%;width:100%;height:2.5px;background:var(--line)}
.pipe .st:first-child::before{display:none}
.pipe .st.done::before,.pipe .st.cur::before{background:var(--teal)}
.pend-box{border-radius:11px;padding:13px 16px;display:flex;gap:11px;align-items:center;font-size:13.5px;margin-top:14px;border:1px solid}
.pend-open{background:#FDF6E9;border-color:#EDD9AE;color:#7A5406}
.pend-done{background:var(--green-bg);border-color:#BFDCC1;color:var(--green)}
.pend-box b{font-weight:600}
.it-tbl{width:100%;border:1px solid var(--line);border-radius:11px;overflow:hidden;border-collapse:separate;border-spacing:0}
.it-tbl th{background:#FAFBFB;font-size:10.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--mute);padding:8px 12px;text-align:left;border-bottom:1px solid var(--line)}
.it-tbl td{padding:8px 12px;font-size:12.5px;border-bottom:1px solid var(--line)}
.it-tbl tr:last-child td{border-bottom:0}
.tl{border-left:2px solid var(--line);margin-left:7px;padding-left:20px}
.tl .ev{position:relative;padding-bottom:15px}
.tl .ev:last-child{padding-bottom:2px}
.tl .ev::before{content:'';position:absolute;left:-27px;top:3px;width:11px;height:11px;border-radius:50%;background:var(--card);border:2.5px solid var(--slate)}
.tl .ev.first::before{border-color:var(--teal);background:var(--teal)}
.tl .ev .ea{font-size:13px;font-weight:500}
.tl .ev .et{font-size:11.5px;color:var(--mute);font-family:var(--mono);margin-top:1px}
.rsn{background:#FAFBFB;border:1px solid var(--line);border-left:3px solid var(--teal);border-radius:0 11px 11px 0;padding:13px 16px;font-size:13.5px;color:var(--slate);line-height:1.65}
.foot-note{font-size:11.5px;color:var(--mute);margin-top:20px;font-family:var(--mono)}
@media print{.side,.head,.fbar,.pager{display:none}.drawer{position:static;width:100%;box-shadow:none}}
</style>
</head>
<body>
<div class="app">



<div class="main">
  <div class="head">
    <span class="mark" style="width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,#0D8A72,#2D6FB2);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;font-family:var(--disp);flex-shrink:0">LG</span>
    <div>
      <h1 id="h-title">LogiGate — request register</h1>
      <div class="sub" id="h-sub">Search any request, check its status, channel, who it's pending with, and move it forward</div>
    </div>
    <span class="spacer"></span>
    <div class="htabs">
      <button id="nav-rg" class="on">Request register <span class="hbd" id="nb-all"></span></button>
    </div>
    <span class="pill-live"><span class="pulse"></span>07-Jul-2026</span>
  </div>

  <div class="content">
    <div id="view-rg">
      <div class="deskstrip" id="deskNav"></div>
      <div class="fbar">
        <input type="text" id="q" placeholder="Search LGR no, requester, reason, item, status…" oninput="S.page=1;render()">
        <select id="f-status" onchange="S.page=1;render()"><option value="">All statuses</option></select>
        <select id="f-owner" onchange="S.page=1;render()"><option value="">Pending with — anyone</option></select>
        <select id="f-channel" onchange="S.page=1;render()"><option value="">All channels</option></select>
        <select id="f-age" onchange="S.page=1;render()">
          <option value="">Any age</option><option value="a">0–3 days</option><option value="b">4–7 days</option>
          <option value="c">8–14 days</option><option value="d">15+ days</option>
        </select>
        <button class="chip-t on" id="t-open" onclick="toggleSet('open')">Open</button>
        <button class="chip-t" id="t-closed" onclick="toggleSet('closed')">Closed</button>
        <span class="count-lbl" id="cnt"></span>
      </div>
      <div class="tbl-wrap">
        <table>
          <thead><tr>
            <th onclick="sortBy('req')">Request<span class="sd" id="s-req"></span></th>
            <th onclick="sortBy('date')">Date<span class="sd" id="s-date"></span></th>
            <th onclick="sortBy('requester')">Requester<span class="sd" id="s-requester"></span></th>
            <th onclick="sortBy('status')">Status<span class="sd" id="s-status"></span></th>
            <th onclick="sortBy('owner')">Pending with<span class="sd" id="s-owner"></span></th>
            <th onclick="sortBy('ch')">Channel<span class="sd" id="s-ch"></span></th>
