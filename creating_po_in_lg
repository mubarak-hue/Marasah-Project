	{
		ftLogiRequest.Vendor_Purchase_Required=false;
		ftLogiRequest.Credit_purchase=true;
	}
}
if(input.Asset_Receiving_Inspection_Checklist != null)
{
	getChecklistRec = Asset_Receiving_Inspection_Checklist[ID == input.Asset_Receiving_Inspection_Checklist];
	getChecklistRec.Purchase_Order_Reference=input.ID;
	if(input.GPS_PO == true)
	{
		getChecklistRec.Status="GPS PO Initiated";
		for each  item in input.Map_PO_to_Checklist
		{
			getCkLst = Asset_Receiving_Inspection_Checklist[ID == item];
			getCkLst.Purchase_Order_Reference=input.ID;
			getCkLst.Prepare_Purchase_Order_for_GPS="Created";
			// 			if(getCkLst.Apply_Insurance == true && getCkLst.Upload_Insurance_bill.size()>0)
			// 			{
			// 				getCkLst.Status = ""
			// 			}
			getCkLst.Attach_GPS_Quotation=ifnull(getChecklistRec.Attach_GPS_Quotation,{});
			if(getCkLst.Completed_On20 == null)
			{
				getCkLst.Completed_On20=zoho.currentdate;
			}
		}
		assetMaster = Asset_Master_Entry[ID == getChecklistRec.Asset_Name];
		assetMaster.Purchase_Order=input.ID;
	}
	else if(input.Insurance_PO == true)
	{
		getChecklistRec.Status="Insurance PO Initiated";
		for each  item in input.Map_PO_to_Checklist
		{
			getCkLst = Asset_Receiving_Inspection_Checklist[ID == item];
			getCkLst.Purchase_Order_Reference=input.ID;
			getCkLst.Purchase_Order_Reference_Insurance="Created";
			// 			getCkLst.Attach_GPS_Quotation=ifnull(getChecklistRec.Attach_GPS_Quotation,{});
			if(getCkLst.Completed_On20 == null)
			{
				getCkLst.Completed_On20=zoho.currentdate;
			}
		}
		assetMaster = Asset_Master_Entry[ID == getChecklistRec.Asset_Name];
		assetMaster.Purchase_Order=input.ID;
	}
}
