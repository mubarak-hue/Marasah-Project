void issue_voucher_from_logiRequest(int lgID)
{
	lgReq = LogiRequest[ID == lgID];
	journalRequired = false;
	transactions_created = true;
	createJournals = false;
	org = "150000132545";
	jrnlMap = Map();
	jrnlMap.put("reference_number",lgReq.Request.toString());
	jrnlMap.put("status","draft");
	linelist = List();
	issuedItems = List();
	try 
	{
		for each  issVh in lgReq.Issue_Voucher1
		{
			try 
			{
				issuvhSubForm = Issue_Voucher_Items_Assets[ID == issVh.ID];
				if(issVh.Transactions_Created == false)
				{
					issuedDate = issuvhSubForm.Issue_Date;
					// -------- ASSET PROCESSING --------
					if(issuvhSubForm.Asset != null)
					{
						try 
						{
							assetMaster = Asset_Master_Entry[ID == issuvhSubForm.Asset];
							if(assetMaster == null)
							{
								transactions_created = false;
								info "Asset not found";
							}
							else
							{
								assetMaster.Project=ifnull(issuvhSubForm.Project.ID,null);
								if(issuvhSubForm.Branch != null)
								{
									getBranch = Branch[ID == issuvhSubForm.Branch].Branch_Name;
									wh = Warehouse[ID != 0];
									matchedName = "";
									for each  det in wh
									{
										if(det.Warehouse_Name.toLowerCase().contains(getBranch.toLowerCase()))
										{
											matchedName = det.Warehouse_Name;
											break;
										}
									}
									assetMaster.Allocated_Location=matchedName;
								}
								if(issuvhSubForm.Department != null)
								{
									assetMaster.Asset_Location1=Department_Master[ID == issuvhSubForm.Department].ID;
								}
								issuvhSubForm.Transactions_Created=true;
							}
							info "Asset issued successfully";
						}
						catch (assetExp)
						{
							info "Asset Processing Error";
							info assetExp;
							transactions_created = false;
						}
					}
					else if(issuvhSubForm.Inventory_Item != null)
					{
						try 
						{
							journalRequired = true;
							invMaster = Inventory_Master[ID == issuvhSubForm.Inventory_Item];
							choosenQty = issuvhSubForm.Issued_Quantity.toDecimal();
							if(invMaster == null)
							{
								transactions_created = false;
								info "Inventory item not found";
								continue;
							}
							whLocID = Warehouse[ID == issuvhSubForm.Warehouse];
							fifoRows = FIFO_Stock_Ledger[Item == invMaster.ID && Warehouse == whLocID.ID && Remaining_Stock > 0] sort by Batch asc;
							totalAvailable = 0;
							stock_taken_batches = List();
							for each  x in fifoRows
							{
								totalAvailable = totalAvailable + ifnull(x.Remaining_Stock,0);
							}
							if(choosenQty > totalAvailable)
							{
								transactions_created = false;
								info "Insufficient stock :" + invMaster.Name;
								continue;
							}
							remainingQty = choosenQty;
							totalItemPrice = 0;
							for each  batch in fifoRows
							{
								try 
								{
									if(remainingQty <= 0)
									{
										break;
									}
									if(batch.Remaining_Stock <= 0)
									{
										continue;
									}
									if(batch.Unit_Price == null || batch.Unit_Price <= 0)
									{
										transactions_created = false;
										info "Unit price missing for inventory batch";
										break;
									}
									if(batch.Remaining_Stock >= remainingQty)
									{
										qtyToTake = remainingQty;
									}
									else
									{
										qtyToTake = batch.Remaining_Stock;
									}
									// ================= SAFETY CHECK =================
									if(qtyToTake > batch.Remaining_Stock)
									{
										transactions_created = false;
										info "Batch stock inconsistency detected";
										break;
									}
									batchTotal = qtyToTake * batch.Unit_Price;
									totalItemPrice = totalItemPrice + batchTotal;
									// update FIFO stock safely
									batch.Remaining_Stock=batch.Remaining_Stock - qtyToTake;
									batch.Stock_In=batch.Remaining_Stock - qtyToTake;
									if(batch.Remaining_Stock < 0)
									{
										batch.Remaining_Stock=0;
									}
									batch.Available_for_Mobilization=toString(batch.Remaining_Stock);
									stock_taken_batches.add(batch.Batch);
									// ================= WAREHOUSE STOCK =================
									wharehouse_lc_stock = Warehouse_Location_Stock[Ware_house_Location == batch.Warehouse && Item == invMaster];
									if(wharehouse_lc_stock != null)
									{
										currentWhStock = ifnull(wharehouse_lc_stock.Available_Stock,0);
										if(currentWhStock < qtyToTake)
										{
											transactions_created = false;
											info "Warehouse stock inconsistency detected. Preventing negative stock.";
											break;
										}
										wharehouse_lc_stock.Available_Stock=currentWhStock - qtyToTake;
										if(wharehouse_lc_stock.Available_Stock < 0)
										{
											wharehouse_lc_stock.Available_Stock=0;
										}
									}
									else
									{
										info "Warehouse stock record missing";
									}
									// ================= CREATE TRANSACTION =================
									try 
									{
										create_Transaction = insert into Transactions
										[
											Added_User=zoho.loginuser
											Transaction_Date=issuvhSubForm.Issue_Date
											Inventory_Item=invMaster.ID
											Destination_Location=issuvhSubForm.Warehouse
											Stock_Out=toString(ifnull(qtyToTake,0.00))
											Unit_Price=batch.Unit_Price
											Total_Price=batch.Total_Price
											LogiRequest=batch.LogiRequest
											Transaction_Type="Issued"
										];
										info "Creating Transactions :" + create_Transaction;
									}
									catch (transExp)
									{
										info "Transaction Creation Error";
										info transExp;
										transactions_created = false;
										break;
									}
									remainingQty = remainingQty - qtyToTake;
								}
								catch (batchExp)
								{
									info "FIFO Batch Processing Error";
									info batchExp;
									transactions_created = false;
									break;
								}
							}
							if(remainingQty > 0 || totalItemPrice <= 0)
							{
								transactions_created = false;
								info "FIFO or pricing issue detected";
								continue;
							}
							// ================= INVENTORY MASTER SAFETY =================
							currentQty = invMaster.Quantity.toDecimal();
							if(currentQty < choosenQty)
							{
								transactions_created = false;
								info "Inventory master inconsistency detected";
								continue;
							}
							invMaster.Quantity=(currentQty - choosenQty).toString();
							if(invMaster.Quantity.toDecimal() < 0)
							{
								invMaster.Quantity="0";
							}
							invMaster.Total_Price=invMaster.Rate * invMaster.Quantity.toDecimal();
							info "Inventory Qty After :" + invMaster.Quantity + " - total price :" + invMaster.Total_Price;
							// ================= JOURNAL SECTION =================
							if(totalItemPrice > 0)
							{
								createJournals = true;
								reportedTagsList = List();
								debitAcc = "1079000000014547";
								creditAcc = Chart_of_Accounts[Account_Code == whLocID.Warehouse_Account_Code].Zoho_Books_ID;
								if(issuvhSubForm.Project != null)
								{
									projectID = Projects[ID == issuvhSubForm.Project].Zoho_Books_ID;
									getProjects = zoho.books.getRecordsByID("projects",org,projectID,"zohobooks3");
									project = getProjects.get("project");
									contractNo = "";
									for each  ln in project.get("custom_fields")
									{
										if(ln.get("field_id") == "1079000002720673")
										{
											contractNo = ln.get("value");
										}
									}
									if(contractNo != "")
									{
										getFGContract = zoho.creator.getRecords("m.alsuhaimi_marasah","finance-operations","All_Project_Contracts","",1,200,"z_creator");
										conDate = getFGContract.get("data");
										tagopID = "";
										zbid = "";
										for each  contX in conDate
										{
											if(contX.get("Contract_No") == contractNo.toString())
											{
												tagopID = contX.get("Tag_Opt_ID");
												zbid = contX.get("Zoho_Books_ID");
												break;
											}
										}
										reportedTagMap = Map();
										reportedTagMap.put("tag_option_id",tagopID);
										reportedTagMap.put("tag_id",zbid);
										reportedTagsList.add(reportedTagMap);
									}
								}
								debit = {"account_id":debitAcc,"amount":totalItemPrice,"debit_or_credit":"debit","description":invMaster.Name,"tags":reportedTagsList,"project_id":projectID};
								credit = {"account_id":creditAcc,"amount":totalItemPrice,"debit_or_credit":"credit","description":invMaster.Name,"tags":reportedTagsList,"project_id":projectID};
								linelist.add(debit);
								linelist.add(credit);
								jrnlMap.put("journal_date",issuvhSubForm.Issue_Date);
								issuedItems.add(issuvhSubForm.ID);
							}
							else
							{
								issuvhSubForm.Transactions_Created=true;
								info "Inventory issued without financial impact";
							}
						}
						catch (invExp)
						{
							info "Inventory Processing Error";
							info invExp;
							transactions_created = false;
						}
					}
					else
					{
						info "The asset / Item already issued";
					}
				}
			}
			catch (mainLoopExp)
			{
				info "Loop Processing Error";
				info mainLoopExp;
				transactions_created = false;
			}
		}
		// ================= JOURNAL CREATION =================
		if(linelist.size() > 0 && createJournals == true)
		{
			try 
			{
				jrnlMap.put("line_items",linelist);
				jrnlMap.put("notes","Issue Voucher journal");
				params = Map();
				params.put("JSONString",jrnlMap);
				response = invokeurl
				[
					url :"https://books.zoho.sa/api/v3/journals?organization_id=" + org
					type :POST
					parameters:params
					connection:"zohobooks1"
				];
				if(response != null && response.get("code") == 0)
				{
					info response.get("message");
					info response.getJSON("journal").get("journal_id");
					for each  issuItem in issuedItems
					{
						issueVh = Issue_Voucher_Items_Assets[ID == issuItem];
						issueVh.Journal_ID=response.getJSON("journal").get("journal_id");
						issueVh.Transactions_Created=true;
					}
				}
				else
				{
					transactions_created = false;
					for each  issueTrans in issuedItems
					{
						issueVh1 = Issue_Voucher_Items_Assets[ID == issueTrans];
						issueVh1.Transactions_Created=false;
					}
					info "Journal creation failed";
					openUrl("#Page:Alert_presets?alert_info=Journal creation failed","popup window","height=auto,width=100%");
				}
			}
			catch (journalExp)
			{
				info "Journal API Error";
				info journalExp;
				transactions_created = false;
			}
		}
		// ===== FINAL STATUS UPDATE =====
		if(transactions_created == true)
		{
			lgReq.Status="Issued";
			info "Issue Voucher Approved";
		}
		else
		{
			lgReq.Status="Mobilization Completed";
			info "Issue Voucher Held";
			openUrl("#Page:Alert_presets?alert_info=Issue Voucher Held, Contact your administrator ","height=auto,width=100%");
		}
	}
	catch (finalExp)
	{
		info "Main Script Error";
		info finalExp;
	}
