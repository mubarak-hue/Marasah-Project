<script>
const DATA = JSON.parse(document.getElementById('lgr-data').textContent);
const CLOSED = new Set(["Completed","Request Canceled","Rejected","Mobilization Completed","Delivery Note & Bill Added / closed","Cash Withdrawal Rejected by GM","Vendor Email Ignored"]);
const ROLE = {
"Pending":"Project in-charge / line manager","Project In-Charge Approved":"Logistics representative",
"Logistics Representative Approved":"Procurement — quotation","Quotation Send":"GM — quotation approval",
"Quotation Approved":"GM","GM Approved":"Finance","GM Approved - Cash Withdrawal":"Requester — cash withdrawal",
"GM Approved – Proceed to Procurement":"Procurement","Request Cash Withdrawal":"GM",
"Finance Approved Payment Requetst":"Chief accountant","Chief Accountant Approved":"Accounting & finance manager",
"Accounting & Finance Manager Approved":"CEO","CEO Approved":"Procurement — initiate PO",
"Initiated PO":"Books — PO creation","PO Added In Books":"GM / Books approver","PO Approved":"Finance",
"PO Approved By GM":"Finance","Finance Approved PO":"Procurement / vendor","Credit PO Approved":"Procurement / vendor",
"Payment Requested":"CEO","Payment Request Sent for CEO Approval":"CEO","Payment Approved by CEO":"Finance — execute payment",
"Payment Request Skipped by Finance":"Procurement","Email Sent to Vendor":"Vendor — awaiting reply",
"PO Revised For Corrections":"Procurement","PO Notes Added":"Procurement",
"Pending Vendor Bills & Delivery Notes":"Logistics — bills & DN","Delivery Note & Bill Added":"Accounts — verification",
"Expense / Bill Created":"Logistics — verify","Expense / Bill Partially Created":"Logistics — verify",
"Expense / Bill Verified by Logistics":"Accounts","Expense / Bill Verified by Accounts":"Chief accountant",
"Expense / Bill Approved by Chief Accounts":"Finance manager","Expense / Bill Approved by Finance Manager":"Closure",
"Under Transportation":"Driver / logistics","Delivered":"Store / receiver","Mobilization Request":"Store keeper",
"Mobilized":"Receiver — confirm","Materials Issued":"Receiver","Asset Issued":"Receiver",
"Create Issue Voucher":"Store keeper","Create Delivery Notes":"Logistics","Issued":"Closure",
"Petty Cash Created":"Finance","Initiated – Additional Payment Request":"GM",
"GM Approved – Additional Payment Request":"Finance","Finance Verified – Additional Payment Request":"CEO",
"CEO Approved – Additional Payment Request":"Finance — execute","Unprocessed Items – Cancellation Requested":"Logistics manager"};
const CANON = ["Initiation","Approvals","PO / payment","Vendor / delivery","Bill verification","Mobilization & issue","Closed"];
const STAGES = CANON;
const APPR=["Pending","Project In-Charge Approved","Logistics Representative Approved","Quotation Send","Quotation Approved","GM Approved","GM Approved - Cash Withdrawal","GM Approved \u2013 Proceed to Procurement","Request Cash Withdrawal","Finance Approved Payment Requetst","Chief Accountant Approved","Accounting & Finance Manager Approved","CEO Approved","Initiated \u2013 Additional Payment Request","GM Approved \u2013 Additional Payment Request","Finance Verified \u2013 Additional Payment Request"];
const POPAY=["Initiated PO","PO Added In Books","PO Approved","PO Approved By GM","Finance Approved PO","Credit PO Approved","Payment Requested","Payment Request Sent for CEO Approval","Payment Approved by CEO","CEO Approved \u2013 Additional Payment Request","Payment Request Skipped by Finance","PO Revised For Corrections","PO Notes Added","Petty Cash Created"];
const VEND=["Email Sent to Vendor","Under Transportation","Delivered","Pending Vendor Bills & Delivery Notes"];
const MOBISS=["Mobilization Request","Mobilized","Materials Issued","Asset Issued","Create Issue Voucher","Create Delivery Notes","Issued"];
const STAGE_OF = s => CLOSED.has(s)?6 : s==="Pending"?0 : APPR.includes(s)?1 : POPAY.includes(s)?2 : VEND.includes(s)?3 : MOBISS.includes(s)?5 : 4;
function isAllDE(r){return r.items&&r.items.length>0&&r.items.every(i=>i.type==='Direct Expense');}
function channelOf(r){
  const allDE=isAllDE(r);
  if(r.vp) return 'Vendor purchase'; if(r.cp) return 'Credit purchase';
  if(!allDE){ if(r.ms) return 'Store mobilization'; if(r.dv) return 'Direct issue voucher'; }
  if(r.pc) return 'Procurement card';
  const st=r.status;
  if(st==='Credit PO Approved') return 'Credit purchase';
  if(!allDE){
    if(st==='Mobilization Request'||st==='Mobilized'||st==='Mobilization Completed') return 'Store mobilization';
    if(st==='Create Issue Voucher'||st==='Issued') return 'Direct issue voucher';
  }
  if(POPAY.includes(st)||VEND.includes(st)) return 'Vendor purchase';
  return 'Not yet classified';
}
const VARIANTS={'Vendor purchase':[0,1,2,3,4,5,6],'Credit purchase':[0,1,2,3,4,5,6],
 'Procurement card':[0,1,2,4,5,6],'Store mobilization':[0,1,5,6],'Direct issue voucher':[0,1,5,6],
 'Not yet classified':[0,1,2,3,4,5,6]};
const CHCOLOR={'Vendor purchase':'#2D6FB2','Credit purchase':'#6A5ACD','Procurement card':'#0D8A72','Store mobilization':'#B4720C','Direct issue voucher':'#3B7D6E','Not yet classified':'#7E8B94'};
const FAMILY = s => {
  if (s==="Completed"||s==="Mobilization Completed"||s==="Delivery Note & Bill Added / closed") return 'f-done';
  if (CLOSED.has(s)) return 'f-bad';
  if (POPAY.includes(s)) return 'f-pay';
  if (VEND.includes(s)) return 'f-vend';
  if (STAGE_OF(s)===4) return 'f-ver';
  return 'f-appr';
};
DATA.forEach(r=>{ r.open=!CLOSED.has(r.status); r.owner=r.open?(ROLE[r.status]||"Review"):"—"; r.stage=STAGE_OF(r.status); r.allDE=isAllDE(r); r.ch=channelOf(r); });

const S={tab:'ov',show:{open:true,closed:false},sort:'age',dir:-1,page:1,per:25};
const esc=s=>String(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const AVC=['#0D8A72','#2D6FB2','#6A5ACD','#B4720C','#B23434','#3B7D6E','#5B6C9E'];
const avt=(name,sz)=>{const p=(name||'?').trim().split(/\s+/);const ini=(p[0]?.[0]||'?')+(p[1]?.[0]||'');
  let h=0;for(const ch of name||'')h=(h*31+ch.charCodeAt(0))>>>0; const c=AVC[h%AVC.length];
  return `<span class="avt" style="background:${c}1E;color:${c};${sz?`width:${sz}px;height:${sz}px;font-size:${sz*.38}px`:''}">${esc(ini.toUpperCase())}</span>`;};

function setTab(t){window.scrollTo(0,0);}
function toggleSet(k){S.show[k]=!S.show[k];if(!S.show.open&&!S.show.closed)S.show[k]=true;
  document.getElementById('t-open').classList.toggle('on',S.show.open);
  document.getElementById('t-closed').classList.toggle('on',S.show.closed);S.page=1;render();}
function sortBy(k){if(S.sort===k)S.dir*=-1;else{S.sort=k;S.dir=(k==='age'||k==='date')?-1:1;}render();}

const ageChip=a=>a==null?'':`<span class="age-b ${a>=15?'a-bad':a>=8?'a-warn':'a-ok'}">${a}d</span>`;
const statusChip=s=>`<span class="chip ${FAMILY(s)}">${esc(s)}</span>`;

function filtered(){
  const q=(document.getElementById('q')?.value||'').toLowerCase();
  const fs=document.getElementById('f-status')?.value||'',fo=document.getElementById('f-owner')?.value||'',fa=document.getElementById('f-age')?.value||'',fc=document.getElementById('f-channel')?.value||'';
  return DATA.filter(r=>{
    if(r.open&&!S.show.open)return false; if(!r.open&&!S.show.closed)return false;
    if(fs&&r.status!==fs)return false; if(fo&&r.owner!==fo)return false; if(fc&&r.ch!==fc)return false;
    if(fa){const a=r.age??-1;
      if(fa==='a'&&!(a>=0&&a<=3))return false; if(fa==='b'&&!(a>=4&&a<=7))return false;
      if(fa==='c'&&!(a>=8&&a<=14))return false; if(fa==='d'&&!(a>=15))return false;}
    if(q){const hay=(r.req+' '+r.requester+' '+r.reason+' '+r.status+' '+r.owner+' '+r.ch+' '+r.items.map(i=>[i.item,i.project,i.dept,i.branch].filter(Boolean).join(' ')).join(' ')).toLowerCase();
      if(!hay.includes(q))return false;}
    return true;});
}
function render(){
  ['req','date','requester','status','owner','ch','age'].forEach(k=>{const e=document.getElementById('s-'+k);if(e)e.textContent=S.sort===k?(S.dir>0?'▲':'▼'):'';});
  const rows=filtered();
  rows.sort((a,b)=>{if(S.sort==='date'||S.sort==='age')return((a.age??-1)-(b.age??-1))*S.dir;
    return String(a[S.sort]).localeCompare(String(b[S.sort]))*S.dir;});
  const pages=Math.max(1,Math.ceil(rows.length/S.per));if(S.page>pages)S.page=pages;
  const slice=rows.slice((S.page-1)*S.per,S.page*S.per);
  document.getElementById('cnt').textContent=rows.length+' request'+(rows.length===1?'':'s');
  document.getElementById('rows').innerHTML=slice.length?slice.map(r=>`
    <tr onclick="openDrawer('${r.id}')">
      <td class="req-no">${esc(r.req)||'—'}</td>
      <td style="white-space:nowrap;font-size:12.5px;color:var(--slate)">${esc(r.date)}</td>
      <td><span class="rq-cell">${avt(r.requester)}${esc(r.requester)}</span></td>
      <td>${statusChip(r.status)}</td>
      <td class="owner-cell">${esc(r.owner)}</td>
      <td><span class="chip" style="background:${CHCOLOR[r.ch]}1A;color:${CHCOLOR[r.ch]}">${esc(r.ch)}</span></td>
      <td>${ageChip(r.age)}</td>
    </tr>`).join(''):`<tr><td colspan="7"><div class="empty">No requests match these filters. Clear a filter to widen the view.</div></td></tr>`;
  document.getElementById('pager').innerHTML=pages>1?`
    <button ${S.page<=1?'disabled':''} onclick="S.page--;render()">‹ Prev</button>
    <span>${S.page} / ${pages}</span>
    <button ${S.page>=pages?'disabled':''} onclick="S.page++;render()">Next ›</button>`:'';
}
function gotoChannel(c){setTab('rg');resetFilters();document.getElementById('f-channel').value=c;render();}
function gotoOwner(o){setTab('rg');resetFilters();document.getElementById('f-owner').value=o;render();}
function gotoStatus(st){setTab('rg');resetFilters();document.getElementById('f-status').value=st;render();}
function gotoStage(i){setTab('rg');resetFilters();S._stage=i;render();/* stage filter via owner list left simple: filter by statuses of stage */
  const sts=[...new Set(DATA.filter(r=>r.open&&r.stage===i).map(r=>r.status))];
  if(sts.length===1)document.getElementById('f-status').value=sts[0];
  else{document.getElementById('q').value='';/* fall back: show open & rely on user */}
  render();}
function gotoAge(idx){setTab('rg');resetFilters();document.getElementById('f-age').value=['a','b','c','d','d'][idx];render();}
function gotoKpi(k){setTab('rg');resetFilters();
  if(k==='closed')S.show={open:false,closed:true};
  if(k==='all')S.show={open:true,closed:true};
  document.getElementById('t-open').classList.toggle('on',S.show.open);
  document.getElementById('t-closed').classList.toggle('on',S.show.closed);
  document.getElementById('f-age').value=k==='risk'?'c':k==='over'?'d':'';render();}
function resetFilters(){S.show={open:true,closed:false};S.page=1;
  document.getElementById('f-status').value='';document.getElementById('f-owner').value='';
  document.getElementById('f-age').value='';document.getElementById('f-channel').value='';document.getElementById('q').value='';
  document.getElementById('t-open').classList.add('on');document.getElementById('t-closed').classList.remove('on');}

const DESKC={'Logistics':'#2D6FB2','Finance':'#6A5ACD','Procurement':'#B4720C','Accounts':'#0D8A72','Vendor':'#B23434','GM':'#3B7D6E','CEO':'#0E1C26','Books':'#5B6C9E','Store':'#7A6A2E'};
const deskColor=o=>{for(const k in DESKC)if(o.startsWith(k))return DESKC[k];return '#46565F';};
const deskIni=o=>o.split(/[\s—-]+/).filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');

function bars(el,entries,clickFn,colorFn){
  const max=Math.max(...entries.map(e=>e[1]),1);
  document.getElementById(el).innerHTML=entries.map(e=>{
    const c=colorFn?colorFn(e[0]):(e[2]||'#2D6FB2');
    return `<div class="brow">
      <span class="bl" title="${esc(e[0])}" ${clickFn?`onclick="${clickFn}('${esc(e[0]).replace(/'/g,"\\'")}')"`:''}>
        ${colorFn?`<span class="dsk" style="background:${c}1E;color:${c}">${deskIni(e[0])}</span>`:''}${esc(e[0])}</span>
      <span class="bt"><span class="bf" data-w="${(e[1]/max*100).toFixed(1)}" style="background:${c}"></span></span>
      <span class="bv">${e[1]}</span></div>`;}).join('');
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    document.querySelectorAll('#'+el+' .bf').forEach(b=>b.style.width=b.dataset.w+'%');}));
}
function countUp(el,to){const dur=700,t0=performance.now();
  const step=t=>{const p=Math.min((t-t0)/dur,1);el.textContent=Math.round(to*(1-Math.pow(1-p,3)));if(p<1)requestAnimationFrame(step);};
  requestAnimationFrame(step);}

function buildOverview(){
  const open=DATA.filter(r=>r.open);
  document.getElementById('nb-all').textContent=DATA.length;
  const m={};open.forEach(r=>{m[r.owner]=(m[r.owner]||0)+1});
  const desks=Object.entries(m).sort((a,b)=>b[1]-a[1]).slice(0,7);
  document.getElementById('deskNav').innerHTML=desks.map(d=>`
    <a onclick="gotoOwner('${esc(d[0]).replace(/'/g,"\\'")}')"><span class="ic" style="color:${deskColor(d[0])}">●</span>${esc(d[0]).split(' — ')[0]}<span class="bd">${d[1]}</span></a>`).join('');
}
function parseLogs(logs){
  return (logs||'').split('\n').map(l=>l.trim()).filter(Boolean).map(l=>{
    const m=l.match(/^(.+?)\s*[-–]\s*[Aa]t\s*:\s*(.+)$/);
    return m?{a:m[1],t:m[2]}:{a:l,t:''};});
}
let CUR=null;
function copyReq(){if(!CUR)return;navigator.clipboard?.writeText(CUR.req);
  const b=document.getElementById('d-copy');b.textContent='copied ✓';setTimeout(()=>b.textContent='copy',1200);}
function openDrawer(id){
  const r=DATA.find(x=>x.id===id);if(!r)return;CUR=r;
  document.getElementById('d-req').textContent=r.req||'(no number)';
  document.getElementById('d-chip').innerHTML=statusChip(r.status)+(r.age!=null?ageChip(r.age):'')+`<span class="chip" style="background:${CHCOLOR[r.ch]}1A;color:${CHCOLOR[r.ch]}">${esc(r.ch)}</span><span style="font-size:12px;color:var(--mute)">requested ${esc(r.date)}</span>`;
  let vstages=(VARIANTS[r.ch]||VARIANTS['Not yet classified']).slice();
  if(r.allDE) vstages=vstages.filter(x=>x!==5);
  let cidx=vstages.indexOf(r.stage); if(cidx<0){cidx=0;for(let i=0;i<vstages.length;i++)if(vstages[i]<=r.stage)cidx=i;}
  const pipe=vstages.map((cs,i)=>`<div class="st ${i<cidx?'done':i===cidx?'cur':''}"><div class="nd"></div><div class="sl">${CANON[cs]}</div></div>`).join('');
  const fm=v=>v==null||v===''?'—':(+v).toLocaleString('en',{maximumFractionDigits:2});
  const items=r.items.length?`<div style="overflow-x:auto"><table class="it-tbl"><tr><th>Type</th><th>Item</th><th>Qty</th><th>Unit</th><th>Unit price</th><th>Project</th><th>Dept</th><th>Branch</th><th>Location</th></tr>${
    r.items.map(i=>`<tr><td style="white-space:nowrap;color:var(--slate)">${esc(i.type)}</td><td style="min-width:140px">${esc(i.item)}</td><td style="font-family:var(--mono)">${fm(i.qty)}</td><td>${esc(i.unit)||'—'}</td><td style="font-family:var(--mono)">${fm(i.price)}</td><td>${esc(i.project)||'—'}</td><td>${esc(i.dept)||'—'}</td><td>${esc(i.branch)||'—'}</td><td style="color:var(--mute)">${esc(i.loc)||'—'}</td></tr>`).join('')}</table></div>`
    :'<div style="font-size:13px;color:var(--mute)">No line items recorded on this request.</div>';
  const evs=parseLogs(r.logs);
  const tl=evs.length?`<div class="tl">${evs.map((e,i)=>`<div class="ev ${i===0?'first':''}"><div class="ea">${esc(e.a)}</div>${e.t?`<div class="et">${esc(e.t)}</div>`:''}</div>`).join('')}</div>`
    :'<div style="font-size:13px;color:var(--mute)">No activity log entries on this record.</div>';
  document.getElementById('d-body').innerHTML=`
    <div class="d-sec"><h4>Position in workflow</h4><div class="pipe">${pipe}</div>
      ${r.open?`<div class="pend-box pend-open">⏳&nbsp; Currently pending with <b>${esc(r.owner)}</b></div>`
              :`<div class="pend-box pend-done">✓&nbsp; This request is closed — no action pending.</div>`}
      ${r.allDE?`<div style="font-size:12px;color:var(--mute);margin-top:8px">All items are direct expense — this request has no mobilization or issue voucher step.</div>`:''}</div>
    <div class="d-sec"><h4>Request details</h4><div class="meta-g">
      <div class="m"><div class="k">Requester</div><div class="v" style="display:flex;align-items:center;gap:8px">${avt(r.requester,22)}${esc(r.requester)||'—'}</div></div>
      <div class="m"><div class="k">Date of request</div><div class="v">${esc(r.date)||'—'}</div></div>
      <div class="m"><div class="k">Project / location</div><div class="v">${esc(r.project||r.loc)||'—'}</div></div>
      <div class="m"><div class="k">Fulfillment channel</div><div class="v" style="color:${CHCOLOR[r.ch]};font-weight:500">${esc(r.ch)}</div></div>
      <div class="m"><div class="k">Amount initiated by Finance</div><div class="v" style="font-family:var(--mono)">${r.iaf!=null&&r.iaf!==''?'SAR '+(+r.iaf).toLocaleString('en',{minimumFractionDigits:2}):'— not in report columns yet'}</div></div>
      ${r.card?`<div class="m"><div class="k">Card holder account</div><div class="v">${esc(r.card)}</div></div>`:''}
      <div class="m"><div class="k">Created by (login)</div><div class="v" style="font-family:var(--mono);font-size:12.5px">${esc(r.addedBy)||'—'}</div></div>
      ${r.pos?`<div class="m"><div class="k">Linked purchase orders</div><div class="v">${r.pos}</div></div>`:''}
    </div></div>
    ${r.reason?`<div class="d-sec"><h4>Reason for request</h4><div class="rsn">${esc(r.reason)}</div></div>`:''}
    <div class="d-sec"><h4>Requested items (${r.items.length})</h4>${items}</div>
    <div class="d-sec"><h4>Activity log</h4>${tl}</div>`;
  document.getElementById('ovl').classList.add('on');
  document.getElementById('drawer').classList.add('on');
}
function closeDrawer(){document.getElementById('ovl').classList.remove('on');document.getElementById('drawer').classList.remove('on');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDrawer();});

(function init(){
  const ss=[...new Set(DATA.map(r=>r.status))].sort();
  document.getElementById('f-status').innerHTML='<option value="">All statuses</option>'+ss.map(s=>`<option>${esc(s)}</option>`).join('');
  const os=[...new Set(DATA.filter(r=>r.open).map(r=>r.owner))].sort();
  const cs=[...new Set(DATA.map(r=>r.ch))].sort();
  document.getElementById('f-channel').innerHTML='<option value="">All channels</option>'+cs.map(c=>`<option>${esc(c)}</option>`).join('');
  document.getElementById('f-owner').innerHTML='<option value="">Pending with — anyone</option>'+os.map(s=>`<option>${esc(s)}</option>`).join('');
  buildOverview();render();
})();
</script>
</body>
</html>
