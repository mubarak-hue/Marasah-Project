    // Close popup
    $(document).on('click', '.popup-close, #popup', function(event) {
        if ($(event.target).is('#popup') || $(event.target).hasClass('popup-close')) {
            $('#popup').fadeOut(function() {
                $(this).remove();
            });
        }
    });
    
    // Assign data-url attribute to attachment links
    $('.attachment').each(function() {
        $(this).attr('data-url', $(this).text());
    });

