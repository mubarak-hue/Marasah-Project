if(input.LogiRequest1 != null)
{
	ftLogiRequest = LogiRequest[ID == input.LogiRequest1];
	// ftLogiRequest.Status = "Initiated PO";
	ftLogiRequest.Purchase_Orders=input.ID;
	ftLogiRequest.Status="Initiated PO";
